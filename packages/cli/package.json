{
  "name": "@claudetree/cli",
  "version": "0.20.0",
  "description": "Issue-to-PR automation: parallel Claude Code sessions with cost tracking, batch processing & web dashboard",
  "type": "module",
  "bin": {
    "claudetree": "./dist/index.js",
    "ct": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:run": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "cli",
    "git",
    "worktree",
    "ai",
    "automation",
    "github-issues",
    "parallel-sessions",
    "cost-tracking"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/wonjangcloud9/claude-tree.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/wonjangcloud9/claude-tree#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@claudetree/core": "workspace:*",
    "@claudetree/shared": "workspace:*",
    "async-mutex": "^0.5.0",
    "commander": "^14.0.3"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.4"
  }
}
