{
  "name": "claudetree",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Issue-to-PR automation: parallel Claude Code sessions with cost tracking, batch processing & web dashboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/wonjangcloud9/claude-tree.git"
  },
  "author": "Lucas",
  "license": "MIT",
  "scripts": {
    "dev": "pnpm run --parallel dev",
    "build": "pnpm run -r build",
    "test": "pnpm -r test:run",
    "test:run": "pnpm -r test:run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint 'packages/*/src/**/*.ts' 'packages/*/src/**/*.tsx'",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "clean": "rm -rf packages/*/dist",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.2",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.39.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vitest": "^3.2.4"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22.0.0"
  }
}
